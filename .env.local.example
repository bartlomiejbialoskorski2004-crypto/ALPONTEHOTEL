# --- Sanity (Studio + content) ---
# Find these at https://www.sanity.io/manage after creating a project.
# Without them, the site still renders with fallback copy from messages/*.json,
# but /studio will not load and Sanity content fetches will be skipped.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# --- Site URL ---
# Used for canonical URLs, hreflang alternates, sitemap.xml, robots.txt, JSON-LD
# and OpenGraph. No trailing slash.
# Production: set to the live custom domain. If this var is missing in
# production, the code falls back to https://www.al-ponte.ch (see lib/site.ts)
# rather than localhost, so canonicals never point at a dev host.
# Local dev: override with http://localhost:3000 in your own .env.local.
NEXT_PUBLIC_SITE_URL=https://www.al-ponte.ch
