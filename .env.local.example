# --- Sanity (Studio + content) ---
# Find these at https://www.sanity.io/manage after creating a project.
# Without them, the site still renders with fallback copy from messages/*.json,
# but /studio will not load and Sanity content fetches will be skipped.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# --- Site URL ---
# Used for canonical URLs, hreflang alternates, sitemap.xml, robots.txt and
# OpenGraph. On Vercel, set this to your production URL (e.g.
# https://alpontehotel.vercel.app or your custom domain). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
