# Copy this file to .env.local and fill in the values for your environment.

# --- Site URL ---
# Public origin of the deployed site. Used for canonical URLs, hreflang
# alternates, sitemap.xml, robots.txt, JSON-LD and OpenGraph. No trailing slash.
# Production: set to your live custom domain.
# Local dev: use http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://twoja-domena.ch

# --- Sanity (Studio + content) — optional ---
# Find these at https://www.sanity.io/manage after creating a project.
# Without them the site still renders with fallback copy from messages/*.json,
# but /studio will not load and Sanity content fetches are skipped.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
